# 노션 API 설정
# 노션 Integrations 페이지에서 발급: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 노션 견적서 데이터베이스 ID
# 노션 데이터베이스 URL에서 추출: https://notion.so/[DATABASE_ID]?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 배포 URL (Vercel 배포 시 설정, 개발 환경에서는 비워둠)
# NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# 공급자(나) 정보
SUPPLIER_NAME=홍길동
SUPPLIER_EMAIL=contact@example.com
SUPPLIER_PHONE=010-1234-5678
SUPPLIER_ADDRESS=서울특별시 강남구 테헤란로 123
